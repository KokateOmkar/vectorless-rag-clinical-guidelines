# Copy this file to ".env" and fill in your keys. NEVER commit .env.

# PageIndex Cloud API key — https://dash.pageindex.ai
PAGEINDEX_API_KEY=your_pageindex_api_key_here

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional overrides (sensible defaults live in config.py) ---
# Primary chat model for tree-search, generation, and judging.
GEMINI_MODEL=gemini-2.5-flash
# Fallback used if the primary model hits its daily quota.
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# Client-side rate limit (requests/min) — keep below the free-tier RPM.
GEMINI_RPM=8
